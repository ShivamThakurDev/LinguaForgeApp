{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=LinguaForge;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "AzureTranslator": {
    "ApiKey": "YOUR_AZURE_TRANSLATOR_KEY",
    "Region": "YOUR_AZURE_REGION"
  },
  "AzureSpeech": {
    "ApiKey": "YOUR_AZURE_SPEECH_KEY",
    "Region": "YOUR_AZURE_REGION"
  },
  "AzureOpenAI": {
    "Endpoint": "https://YOUR_RESOURCE_NAME.openai.azure.com/",
    "ApiKey": "YOUR_AZURE_OPENAI_KEY",
    "DeploymentName": "YOUR_DEPLOYMENT_NAME"
  },
  "Jwt": {
    "Key": "CHANGE_ME_TO_A_LONG_RANDOM_SECRET",
    "Issuer": "LinguaForge",
    "Audience": "LinguaForge",
    "ExpiryMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
